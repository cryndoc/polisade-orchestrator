# PDLC state (regenerated by Claude)
.state/
!.state/knowledge.json

# PDLC intermediate artefacts (PR body, diff snapshots, reports).
# Project-local temp — /tmp is NOT used because GigaCode CLI sandboxes it
# via a virtual FS (~/.gigacode/tmp/<hash>/), which breaks cross-step reads
# (issue #57 / legacy OPS-009; docs/gigacode-cli-notes.md §4).
.pdlc/tmp/

# PDLC CLI extensions — service dirs with secret paths, prompt snippets, etc.
# Must NEVER be committed (see Git Safety in CLAUDE.md, issue #74).
# NB: .claude/ intentionally NOT listed — it stores committed
# settings.json (plugin permissions) for Claude Code target.
.gigacode/
.qwen/
.codex/
.worktrees/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Dependencies (uncomment as needed for your stack)
# node_modules/          # Node.js / TypeScript
# vendor/                # Go, PHP, Ruby
# __pycache__/           # Python
# *.pyc                  # Python
# .venv/                 # Python virtualenv
# .gradle/               # Gradle (Java / Kotlin / Scala)
# .m2/                   # Maven local cache

