# Bitbucket Server: два домена, два токена.
# Имена DOMAIN1/DOMAIN2 — произвольные: замените URL и токены на свои.
# Плагин выбирает инстанс автоматически по host из `git remote get-url origin`.
#
# Заполните только те домены, которые используете. Достаточно одного.
# После заполнения запустите `/pdlc:doctor` — он проверит токен и доступ.

BITBUCKET_DOMAIN1_URL=https://bitbucket.example.com
BITBUCKET_DOMAIN1_TOKEN=
# bearer (default) | basic — попробуйте basic при 401
BITBUCKET_DOMAIN1_AUTH_TYPE=bearer
# только для basic
BITBUCKET_DOMAIN1_USER=

BITBUCKET_DOMAIN2_URL=https://stash.example.org
BITBUCKET_DOMAIN2_TOKEN=
BITBUCKET_DOMAIN2_AUTH_TYPE=bearer
BITBUCKET_DOMAIN2_USER=
